set $super Mod4
set $alt Mod1

set $left h
set $down j
set $up k
set $right l

output * bg ~/Pictures/wallpapers/evening-sky.png fill

bindsym $super+Return exec alacritty
bindsym $super+d exec rofi -show drun 
bindsym $super+q kill

floating_modifier $super normal
bindsym $super+Shift+c reload
bindsym $super+Shift+e exec swaynag -t warning -m 'You pressed the exit shortcut. Do you really want to exit sway? This will end your Wayland session.' -B 'Yes, exit sway' 'swaymsg exit'

bindsym $super+$left focus left
bindsym $super+$down focus down
bindsym $super+$up focus up
bindsym $super+$right focus right

bindsym $super+Shift+$left move left
bindsym $super+Shift+$down move down
bindsym $super+Shift+$up move up
bindsym $super+Shift+$right move right
    
bindsym $super+b splith
bindsym $super+v splitv

bindsym $super+e layout toggle split
bindsym $super+f fullscreen
bindsym $super+space floating toggle
bindsym $super+Shift+space focus mode_toggle

mode "resize" {
    bindsym $left resize shrink width 10px
    bindsym $down resize grow height 10px
    bindsym $up resize shrink height 10px
    bindsym $right resize grow width 10px

    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $super+r mode "resize"

bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

bindsym Print exec grim -g "$(slurp)" - | wl-copy && wl-paste > ~/Pictures/captures/$(date +%F_%T).png | dunstify "Screenshot of the region taken" -t 1000 # screenshot of a region 

include /etc/sway/config.d/*
include ~/.config/sway_monitors

input type:touchpad {
    tap enabled
    accel_profile "flat"
    pointer_accel 0.3
    drag_lock disabled
}

default_border none 
